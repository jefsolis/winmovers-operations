generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Client {
  id         String    @id @default(cuid())
  clientType String    @default("CORPORATE")
  name       String
  firstName  String?
  lastName   String?
  accountNum String?   @unique
  email      String?
  phone      String?
  address    String?
  country    String?
  notes      String?
  contacts   Contact[]
  jobs       Job[]
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

model Contact {
  id        String   @id @default(cuid())
  firstName String
  lastName  String
  email     String?
  phone     String?
  clientId  String?
  client    Client?  @relation(fields: [clientId], references: [id])
  jobs      Job[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Agent {
  id        String   @id @default(cuid())
  name      String
  agentType String
  country   String?
  city      String?
  email     String?
  phone     String?
  notes     String?
  originJobs      Job[]    @relation("OriginAgent")
  destJobs        Job[]    @relation("DestAgent")
  customsJobs     Job[]    @relation("CustomsAgent")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Job {
  id            String    @id @default(cuid())
  jobNumber     String    @unique
  type          String
  status        String    @default("SURVEY")
  clientId      String?
  client        Client?   @relation(fields: [clientId], references: [id])
  contactId     String?
  contact       Contact?  @relation(fields: [contactId], references: [id])
  originAgentId  String?
  originAgent    Agent?    @relation("OriginAgent", fields: [originAgentId], references: [id])
  destAgentId    String?
  destAgent      Agent?    @relation("DestAgent", fields: [destAgentId], references: [id])
  customsAgentId String?
  customsAgent   Agent?    @relation("CustomsAgent", fields: [customsAgentId], references: [id])
  originCity    String?
  originCountry String?
  destCity      String?
  destCountry   String?
  callDate      DateTime?
  surveyDate    DateTime?
  packDate      DateTime?
  moveDate      DateTime?
  deliveryDate  DateTime?
  volumeCbm     Float?
  weightKg      Float?
  shipmentMode  String?
  notes         String?
  files         JobFile[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model JobFile {
  id          String   @id @default(cuid())
  jobId       String
  job         Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  category    String   @default("OTHER")
  filename    String
  storagePath String
  sizeBytes   Int?
  uploadedAt  DateTime @default(now())
}
