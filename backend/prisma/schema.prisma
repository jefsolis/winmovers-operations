generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Client {
  id         String    @id @default(cuid())
  clientType String    @default("CORPORATE")
  name       String
  firstName  String?
  lastName   String?
  accountNum String?   @unique
  email      String?
  phone      String?
  address    String?
  country    String?
  notes      String?
  contacts   Contact[]
  jobs       Job[]
  visits     Visit[]
  movingFiles MovingFile[]
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

model Contact {
  id        String   @id @default(cuid())
  firstName String
  lastName  String
  email     String?
  phone     String?
  clientId  String?
  client    Client?  @relation(fields: [clientId], references: [id])
  jobs      Job[]
  visits    Visit[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Agent {
  id        String   @id @default(cuid())
  name      String
  agentType String
  country   String?
  city      String?
  email     String?
  phone     String?
  notes     String?
  originJobs      Job[]    @relation("OriginAgent")
  destJobs        Job[]    @relation("DestAgent")
  customsJobs     Job[]    @relation("CustomsAgent")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Job {
  id            String      @id @default(cuid())
  jobNumber     String      @unique
  type          String
  status        String      @default("SURVEY")
  clientId      String?
  client        Client?     @relation(fields: [clientId], references: [id])
  contactId     String?
  contact       Contact?    @relation(fields: [contactId], references: [id])
  originAgentId  String?
  originAgent    Agent?      @relation("OriginAgent", fields: [originAgentId], references: [id])
  destAgentId    String?
  destAgent      Agent?      @relation("DestAgent", fields: [destAgentId], references: [id])
  customsAgentId String?
  customsAgent   Agent?      @relation("CustomsAgent", fields: [customsAgentId], references: [id])
  originAddress String?
  originCity    String?
  originCountry String?
  destAddress   String?
  destCity      String?
  destCountry   String?
  callDate      DateTime?
  surveyDate    DateTime?
  packDate      DateTime?
  moveDate      DateTime?
  deliveryDate  DateTime?
  volumeCbm     Float?
  weightKg      Float?
  shipmentMode  String?
  notes         String?
  serviceDate     DateTime?
  serviceTime     String?
  clientPhone     String?
  clientHomePhone String?
  companyName     String?
  companyPhone    String?
  serviceDetails  String?     @db.Text
  materials       String?     @db.Text
  quoteTo         String?
  creatorName     String?
  language        String      @default("EN")
  quoteId         String?     @unique
  quote           Quote?      @relation(fields: [quoteId], references: [id])
  movingFileId    String?     @unique
  movingFile      MovingFile? @relation(fields: [movingFileId], references: [id])
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

// ── File (Expediente) ─────────────────────────────────────────────────────────
// A File is the physical/administrative folder for a move.
// category: EXPORT (E-####) | IMPORT (D-####) | LOCAL (M-####)
// LOCAL files have no Job; EXPORT jobs share the same number as the File.
model MovingFile {
  id          String       @id @default(cuid())
  fileNumber  String       @unique
  category    String       // EXPORT | IMPORT | LOCAL
  status      String       @default("OPEN") // OPEN | CLOSED
  clientId    String?
  client      Client?      @relation(fields: [clientId], references: [id])
  notes       String?
  job         Job?         // back-relation; null for LOCAL files
  attachments Attachment[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Attachment {
  id          String     @id @default(cuid())
  fileId      String
  movingFile  MovingFile @relation(fields: [fileId], references: [id], onDelete: Cascade)
  category    String     @default("OTHER")
  filename    String
  storagePath String
  sizeBytes   Int?
  uploadedAt  DateTime   @default(now())
}

model StaffMember {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  phone     String?
  isActive  Boolean  @default(true)
  visits    Visit[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Visit {
  id            String       @id @default(cuid())
  visitNumber   String       @unique
  status        String       @default("SCHEDULED")
  // Prospect info (for leads not yet in the system)
  prospectName  String?
  prospectPhone String?
  prospectEmail String?
  // Optional links to existing records
  clientId      String?
  client        Client?      @relation(fields: [clientId], references: [id])
  contactId     String?
  contact       Contact?     @relation(fields: [contactId], references: [id])
  // Assigned staff member
  assignedToId  String?
  assignedTo    StaffMember? @relation(fields: [assignedToId], references: [id])
  // Route
  originAddress String?
  originCity    String?
  originCountry String?
  destAddress   String?
  destCity      String?
  destCountry   String?
  // Service
  serviceType   String?
  language      String    @default("EN")
  scheduledDate DateTime?
  observations  String?
  quotes        Quote[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

model Quote {
  id          String    @id @default(cuid())
  quoteNumber String    @unique
  visitId     String
  visit       Visit     @relation(fields: [visitId], references: [id], onDelete: Cascade)
  status      String    @default("DRAFT")
  totalAmount Float?
  currency    String    @default("USD")
  validUntil  DateTime?
  notes       String?
  language    String    @default("EN")
  content     String?   @db.Text
  creatorName String?
  job         Job?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}
