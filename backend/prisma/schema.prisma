generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Client {
  id         String    @id @default(cuid())
  clientType String    @default("CORPORATE")
  name       String
  firstName  String?
  lastName   String?
  accountNum String?   @unique
  email      String?
  phone      String?
  address    String?
  country    String?
  notes      String?
  jobs            Job[]
  visits          Visit[]              @relation("VisitClient")
  corporateVisits Visit[]              @relation("VisitCorporateClient")
  movingFiles          MovingFile[]         @relation("FileClient")
  corporateMovingFiles MovingFile[]         @relation("FileCorporateClient")
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

model Agent {
  id        String   @id @default(cuid())
  name      String
  country   String?
  city      String?
  email     String?
  phone     String?
  notes     String?
  originJobs      Job[]    @relation("OriginAgent")
  destJobs        Job[]    @relation("DestAgent")
  customsJobs     Job[]    @relation("CustomsAgent")
  originFiles     MovingFile[] @relation("FileOriginAgent")
  destFiles       MovingFile[] @relation("FileDestAgent")
  originVisits    Visit[]      @relation("VisitOriginAgent")
  destVisits      Visit[]      @relation("VisitDestAgent")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Job {
  id            String      @id @default(cuid())
  jobNumber     String      @unique
  type          String
  status        String      @default("SURVEY")
  clientId      String?
  client        Client?     @relation(fields: [clientId], references: [id])
  originAgentId  String?
  originAgent    Agent?      @relation("OriginAgent", fields: [originAgentId], references: [id])
  destAgentId    String?
  destAgent      Agent?      @relation("DestAgent", fields: [destAgentId], references: [id])
  customsAgentId String?
  customsAgent   Agent?      @relation("CustomsAgent", fields: [customsAgentId], references: [id])
  originAddress String?
  originCity    String?
  originCountry String?
  destAddress   String?
  destCity      String?
  destCountry   String?
  callDate      DateTime?
  surveyDate    DateTime?
  packDate      DateTime?
  moveDate      DateTime?
  deliveryDate  DateTime?
  volumeCbm     Float?
  weightKg      Float?
  shipmentMode  String?
  notes         String?
  serviceDate     DateTime?
  serviceTime     String?
  clientPhone     String?
  clientHomePhone String?
  companyName     String?
  companyPhone    String?
  serviceDetails  String?     @db.Text
  materials       String?     @db.Text
  quoteTo         String?
  creatorName     String?
  contacto        String?
  bultos          Int?
  personalCount   Int?
  transbordo      Boolean?
  language        String      @default("EN")
  quoteId         String?     @unique
  quote           Quote?      @relation(fields: [quoteId], references: [id])
  movingFileId    String?     @unique
  movingFile      MovingFile? @relation(fields: [movingFileId], references: [id])
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

// ── File (Expediente) ─────────────────────────────────────────────────────────
// A File is the physical/administrative folder for a move.
// category: EXPORT (E-####) | IMPORT (D-####) | LOCAL (M-####)
// LOCAL files have no Job; EXPORT jobs share the same number as the File.
model MovingFile {
  id          String       @id @default(cuid())
  fileNumber  String       @unique
  category    String       // EXPORT | IMPORT | LOCAL
  status      String       @default("OPEN") // OPEN | CLOSED
  clientId    String?
  client      Client?      @relation("FileClient", fields: [clientId], references: [id])
  corporateClientId String?
  corporateClient   Client?  @relation("FileCorporateClient", fields: [corporateClientId], references: [id])
  notes         String?
  serviceType   String?
  shipmentMode  String?
  volumeCbm     Float?
  weightKg      Float?
  bookerRole    String?
  originAgentId String?
  originAgent   Agent?   @relation("FileOriginAgent", fields: [originAgentId], references: [id])
  destAgentId   String?
  destAgent     Agent?   @relation("FileDestAgent", fields: [destAgentId], references: [id])
  damageReportData String?  @db.Text
  evaluationData   String?  @db.Text
  job         Job?         // back-relation; null for LOCAL files
  attachments Attachment[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Attachment {
  id          String     @id @default(cuid())
  fileId      String
  movingFile  MovingFile @relation(fields: [fileId], references: [id], onDelete: Cascade)
  category    String     @default("OTHER")
  filename    String
  storagePath String
  sizeBytes   Int?
  uploadedAt  DateTime   @default(now())
}

model StaffMember {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  phone     String?
  isActive  Boolean  @default(true)
  visits    Visit[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Visit {
  id            String       @id @default(cuid())
  visitNumber   String       @unique
  status        String       @default("SCHEDULED")
  // Prospect info (for leads not yet in the system)
  prospectName  String?
  prospectPhone String?
  prospectEmail String?
  // Optional links to existing records
  clientId          String?
  client            Client?      @relation("VisitClient", fields: [clientId], references: [id])
  corporateClientId String?
  corporateClient   Client?      @relation("VisitCorporateClient", fields: [corporateClientId], references: [id])

  // Assigned staff member
  assignedToId  String?
  assignedTo    StaffMember? @relation(fields: [assignedToId], references: [id])
  // Route
  originAddress String?
  originCity    String?
  originCountry String?
  destAddress   String?
  destCity      String?
  destCountry   String?
  // Service
  serviceType   String?
  language      String    @default("EN")
  scheduledDate DateTime?
  observations  String?
  bookerRole    String?
  originAgentId String?
  originAgent   Agent?   @relation("VisitOriginAgent", fields: [originAgentId], references: [id])
  destAgentId   String?
  destAgent     Agent?   @relation("VisitDestAgent", fields: [destAgentId], references: [id])
  quotes        Quote[]
  survey        SurveyCubicFeet?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

model SurveyCubicFeet {
  id                String       @id @default(cuid())
  surveyNumber      String       @unique
  visitId           String       @unique
  visit             Visit        @relation(fields: [visitId], references: [id])
  surveyDate        DateTime?
  surveyorName      String?
  totalCf           Float?
  cubeWeightFactor  Float        @default(6)
  notes             String?
  items             SurveyItem[]
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
}

model SurveyItem {
  id          String          @id @default(cuid())
  surveyId    String
  survey      SurveyCubicFeet @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  room        String
  description String
  qty         Int             @default(1)
  cfPerItem   Float           @default(0)
  totalCf     Float           @default(0)
}

model Quote {
  id          String    @id @default(cuid())
  quoteNumber String    @unique
  visitId     String
  visit       Visit     @relation(fields: [visitId], references: [id], onDelete: Cascade)
  status      String    @default("DRAFT")
  totalAmount Float?
  currency    String    @default("USD")
  validUntil  DateTime?
  notes       String?
  language    String    @default("EN")
  content     String?   @db.Text
  creatorName String?
  job         Job?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}
